{
    "manifest_version": 3,
    "name": "YT Sentiment — Comment Analyzer",
    "version": "1.0.0",
    "description": "Analyze the sentiment of YouTube comments instantly using AI. See positive, neutral & negative breakdown.",

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16":  "icons/icon16.png",
            "48":  "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },

    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],

    "host_permissions": [
        "https://www.youtube.com/*"
    ],

    "content_scripts": [
        {
            "matches": ["https://www.youtube.com/watch*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],

    "background": {
        "service_worker": "background.js"
    },

    "icons": {
        "16":  "icons/icon16.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
